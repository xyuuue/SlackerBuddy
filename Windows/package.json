{
  "name": "slackerbuddy-windows",
  "version": "1.0.0",
  "description": "SlackerBuddy desktop pet for Windows.",
  "author": "Yueling Qiu <lindaqiuyueling@gmail.com>",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir --win --x64",
    "dist": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.yuelingqiu.slackerbuddy",
    "productName": "SlackerBuddy",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/SlackerBuddy.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SlackerBuddy"
    }
  }
}
